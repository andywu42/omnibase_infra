# =============================================================================
# ONEX Infrastructure -- Bootstrap Environment Configuration
# =============================================================================
# This file contains ONLY the values needed to bootstrap the infrastructure.
# After bootstrap, runtime configuration is managed by Infisical.
#
# Setup:
#   cp .env.example .env
#   # Set POSTGRES_PASSWORD below
#   # Optionally configure Infisical identity (see scripts/setup-infisical-identity.sh)
#   ./scripts/bootstrap-infisical.sh
#
# For the full pre-Infisical configuration, see docs/env-example-full.txt
#
# SECURITY:
#   - Generate passwords with: openssl rand -hex 32
#   - Never commit .env to version control
# =============================================================================

# --- Required: Database ---
POSTGRES_PASSWORD=__REPLACE_WITH_SECURE_PASSWORD__

# --- Optional: Database DSN (overrides default construction) ---
# OMNIBASE_INFRA_DB_URL=postgresql://postgres:${POSTGRES_PASSWORD}@localhost:5436/omnibase_infra

# --- Required: Infisical Encryption (needed when using --profile secrets/full/bootstrap) ---
# Generate INFISICAL_ENCRYPTION_KEY with: openssl rand -hex 16
# Generate INFISICAL_AUTH_SECRET with: openssl rand -hex 32
# These are required by docker-compose.infra.yml (no inline defaults -- Infisical refuses
# to start without them). Set placeholder values here; replace before first use.
INFISICAL_ENCRYPTION_KEY=CHANGE_ME_generate_with_openssl_rand_hex_16
INFISICAL_AUTH_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_32

# --- Optional: Infisical Secrets Management ---
# Set these after running scripts/setup-infisical-identity.sh
# INFISICAL_ADDR=http://localhost:8880
# INFISICAL_CLIENT_ID=
# INFISICAL_CLIENT_SECRET=
# INFISICAL_PROJECT_ID=

# --- Optional: Valkey Cache ---
# VALKEY_PASSWORD=valkey-dev-password

# --- Optional: ONEX State ---
# Directory for hook and pipeline state management.
# Must exist on disk; used by omniclaude state manager and agent workflows.
# ONEX_STATE_DIR=

# --- Optional: Logging ---
# ONEX_LOG_LEVEL=INFO
# ONEX_ENVIRONMENT=development
