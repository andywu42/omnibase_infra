# =============================================================================
# MASTER ENVIRONMENT TEMPLATE — OmniNode Platform
# Generated from env var inventory 2026-04-07 (OMN-7771)
# Total variables: 167 across 11 repositories
# =============================================================================
#
# USAGE:
#   cp env/.env.master .env
#   # Edit values for your environment
#   python scripts/validate_env.py
#
# LEGEND:
#   [REQUIRED]     — Service will crash without this
#   [CONDITIONAL]  — Required when a feature flag is enabled
#   [OPTIONAL]     — Has a sensible default or feature is optional
#   [DEPRECATED]   — Scheduled for removal; migrate to the noted replacement
#
# =============================================================================


# =============================================================================
# INFRASTRUCTURE — Kafka / Redpanda
# =============================================================================

# Broker addresses for event-driven architecture
# Format: host1:port1,host2:port2
# Used by: omniclaude, omniintelligence, omnidash, omnimemory, omnimarket
KAFKA_BOOTSTRAP_SERVERS=192.168.86.201:19092

# Allowlist for Kafka broker validation (omniintelligence)
# KAFKA_BROKER_ALLOWLIST=

# Environment label for logging/observability only (NOT topic prefixing per OMN-1972)
# Values: dev, staging, prod
KAFKA_ENVIRONMENT=dev

# Consumer group IDs (per-service defaults)
# KAFKA_GROUP_ID=omniclaude-hooks
# KAFKA_CONSUMER_GROUP_ID=omnidash-consumers-v2
# KAFKA_CLIENT_ID=omnidash-event-consumer
# KAFKA_HEALTH_CHECK_CLIENT_ID=omnidash-health-check

# Timeouts (milliseconds)
KAFKA_REQUEST_TIMEOUT_MS=5000
KAFKA_CONNECTION_TIMEOUT_MS=3000

# Retry configuration (omnidash)
KAFKA_MAX_RETRIES=5
KAFKA_RETRY_BASE_DELAY_MS=1000
KAFKA_RETRY_MAX_DELAY_MS=30000

# Operation-specific timeouts (omnidash)
KAFKA_PATTERN_DISCOVERY_TIMEOUT_MS=5000
KAFKA_CODE_ANALYSIS_TIMEOUT_MS=10000
KAFKA_QUALITY_ASSESSMENT_TIMEOUT_MS=10000

# Enable Kafka-based intelligence operations
KAFKA_ENABLE_INTELLIGENCE=true

# Enable real-time event publishing
ENABLE_REAL_TIME_EVENTS=true

# Enable Kafka event logging to console (omnidash)
ENABLE_KAFKA_LOGGING=true

# Dual-publish to legacy topics during migration (OMN-2368)
# [DEPRECATED] — remove after migration complete
DUAL_PUBLISH_LEGACY_TOPICS=false

# Allow default Kafka config when servers not explicitly set (omniintelligence)
OMNIINTELLIGENCE_ALLOW_DEFAULT_KAFKA=true


# =============================================================================
# DATABASE — PostgreSQL
# =============================================================================

# Shared PostgreSQL connection parameters
# [CONDITIONAL] Required when ENABLE_POSTGRES=true and no full DB URL set
POSTGRES_HOST=192.168.86.201
POSTGRES_PORT=5436
POSTGRES_USER=
POSTGRES_PASSWORD=

# WARNING: POSTGRES_DATABASE has a collision between services.
# omnidash sets it to "omnidash_analytics", omniclaude expects its own DB name.
# Use service-specific *_DB_URL variables instead.
# POSTGRES_DATABASE=

# Service-specific full connection URLs (preferred over individual POSTGRES_* fields)
# Format: postgresql://user:password@host:port/dbname
# OMNICLAUDE_DB_URL=
# OMNIDASH_ANALYTICS_DB_URL=
# OMNIINTELLIGENCE_DB_URL=
# OMNIMEMORY_DB_URL=
# OMNIBASE_INFRA_DB_URL=
# OMNIWEB_DB_URL=

# Service-specific database name (omniclaude, avoids POSTGRES_DATABASE collision)
# OMNICLAUDE_POSTGRES_DATABASE=

# [DEPRECATED] Use OMNIDASH_ANALYTICS_DB_URL instead
# DATABASE_URL=

# Enable PostgreSQL connection (omniclaude, safe default: false)
ENABLE_POSTGRES=false

# Connection pool settings (omniintelligence)
POSTGRES_MIN_POOL_SIZE=2
POSTGRES_MAX_POOL_SIZE=10
POSTGRES_COMMAND_TIMEOUT=60.0

# Connection pool settings (omnidash)
DB_POOL_MAX_CONNECTIONS=20
DB_POOL_MIN_CONNECTIONS=2
DB_POOL_IDLE_TIMEOUT_MS=30000

# Test database (omnidash tests only)
# TEST_DATABASE_URL=


# =============================================================================
# VECTOR DATABASE — Qdrant
# =============================================================================

# Full Qdrant URL (takes precedence over QDRANT_HOST:QDRANT_PORT)
# Format: http://localhost:6333
# QDRANT_URL=

# Individual connection parameters
# QDRANT_HOST=
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334

# Docker image version
QDRANT_VERSION=v1.16.3

# API key (required for production)
# QDRANT_API_KEY=

# Enable HTTPS for Qdrant connections
QDRANT_HTTPS=false

# Docker resource limits (dev defaults)
QDRANT_CPU_LIMIT=2.0
QDRANT_MEMORY_LIMIT=2G

# Enable Qdrant vector database (omniclaude)
ENABLE_QDRANT=false


# =============================================================================
# CACHE — Valkey (Redis-compatible)
# =============================================================================

# Full Valkey connection URL
# Format: redis://:password@host:6379/db_number
# VALKEY_URL=

VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_VERSION=8

# Authentication (required for production)
# VALKEY_PASSWORD=

# Enable intelligence cache (omniclaude)
ENABLE_INTELLIGENCE_CACHE=true

# Cache TTL per entry type (seconds)
CACHE_TTL_PATTERNS=300
CACHE_TTL_INFRASTRUCTURE=3600
CACHE_TTL_SCHEMAS=1800


# =============================================================================
# LLM & AI SERVICES
# =============================================================================

# Local inference endpoints (vLLM on .201 server)
LLM_CODER_URL=http://192.168.86.201:8000
LLM_EMBEDDING_URL=http://192.168.86.201:8002
# LLM_EMBEDDING_URL_ALT=
LLM_FUNCTION_URL=http://192.168.86.201:8001
LLM_QWEN_72B_URL=http://192.168.86.201:8100
# LLM_QWEN_72B_URL_ALT=
LLM_QWEN_14B_URL=http://192.168.86.201:8200
LLM_VISION_URL=http://192.168.86.201:8102
LLM_DEEPSEEK_R1_URL=http://192.168.86.201:8001

# GLM delegation pipeline (OMN-7103)
# LLM_GLM_URL=
# LLM_GLM_API_KEY=
# LLM_GLM_MODEL_NAME=


# =============================================================================
# AUTH — API Keys & Credentials
# =============================================================================

# Third-party AI providers
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=
# GOOGLE_API_KEY=
# Z_AI_API_KEY=
# Z_AI_API_URL=https://api.z.ai/api/coding/paas/v4

# GitHub
# GITHUB_TOKEN=ghp_...
# GH_PAT=

# Slack notifications (omniclaude hooks)
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_WEBHOOK_URL=

# Linear (optional deep dive reports)
# LINEAR_API_KEY=
# LINEAR_INSIGHTS_OUTPUT_DIR=

# Keycloak OAuth/OIDC (omniweb)
# KEYCLOAK_ISSUER=https://auth.omninode.ai/realms/omninode
# KEYCLOAK_CLIENT_ID=
# KEYCLOAK_CLIENT_SECRET=

# OmniNode service credentials (omniweb)
# ONEX_SERVICE_CLIENT_ID=
# ONEX_SERVICE_CLIENT_SECRET=


# =============================================================================
# INFISICAL — Secrets Management
# =============================================================================

# [REQUIRED when using Infisical]
# Generate: openssl rand -hex 16
# INFISICAL_ENCRYPTION_KEY=
# INFISICAL_AUTH_SECRET=

# Post-bootstrap configuration
# INFISICAL_ADDR=
# INFISICAL_CLIENT_ID=
# INFISICAL_CLIENT_SECRET=
# INFISICAL_PROJECT_ID=


# =============================================================================
# SERVICE ENDPOINTS
# =============================================================================

# Intelligence service
# INTELLIGENCE_SERVICE_URL=http://localhost:8053

# OmniClaude context API (overrides INTELLIGENCE_SERVICE_URL)
# OMNICLAUDE_CONTEXT_API_URL=http://localhost:8053
OMNICLAUDE_CONTEXT_API_ENABLED=true
OMNICLAUDE_CONTEXT_API_TIMEOUT_MS=900

# [DEPRECATED] Use INTELLIGENCE_SERVICE_URL instead
# ARCHON_INTELLIGENCE_URL=

# Main server URL (features disabled when not set)
# MAIN_SERVER_URL=

# Semantic search
# SEMANTIC_SEARCH_URL=

# Agent learning retrieval (Cross-Agent Memory Fabric, OMN-7248)
# AGENT_LEARNING_RETRIEVAL_URL=http://localhost:8085/v1/nodes/node_agent_learning_retrieval_effect/execute

# OmniNode API (omniweb)
# ONEX_API_BASE_URL=https://api.omninode.ai

# Z.ai external API
# Z_AI_API_URL=https://api.z.ai/api/coding/paas/v4

# Health check server port (omniclaude)
HEALTH_CHECK_PORT=8070

# Intelligence API external port (Docker)
INTELLIGENCE_API_EXTERNAL_PORT=8053


# =============================================================================
# FEATURE FLAGS
# =============================================================================

# Event-based agent routing via Kafka (omniclaude)
USE_EVENT_ROUTING=false

# ONEX routing nodes (omniclaude)
USE_ONEX_ROUTING_NODES=false

# LLM-based agent routing (omniclaude)
USE_LLM_ROUTING=false
LLM_ROUTING_TIMEOUT_S=0.1

# Shadow validation for delegation comparison
# ENABLE_SHADOW_VALIDATION=false

# Pattern quality tuning (enforcement is unconditional — OMN-8780)
ENABLE_PATTERN_QUALITY_FILTER=false
MIN_PATTERN_QUALITY=0.5
ENABLE_DISABLED_PATTERN_FILTER=true

# Quality enforcement phases (omniclaude)
ENABLE_PHASE_1_VALIDATION=true
ENABLE_PHASE_2_STRUCTURAL=true
ENABLE_PHASE_3_SEMANTIC=true
ENABLE_PHASE_4_AI_QUORUM=false
ENFORCEMENT_MODE=advisory
PERFORMANCE_BUDGET_SECONDS=2.0

# Constraint injection (OMN-6816)
OMNICLAUDE_CONSTRAINT_INJECTION_ENABLED=true
OMNICLAUDE_CONSTRAINT_MAX_ITEMS=10

# A/B testing cohort control
OMNICLAUDE_COHORT_CONTROL_PERCENTAGE=20
OMNICLAUDE_COHORT_SALT=omniclaude-injection-v1

# OmniClaude context API toggle
# OMNICLAUDE_CONTEXT_API_ENABLED=true

# Demo mode — mock data generators (omnidash)
DEMO_MODE=false
VITE_USE_MOCK_DATA=false

# Event intelligence (omnidash)
ENABLE_EVENT_INTELLIGENCE=true
ENABLE_EVENT_PRELOAD=true

# Read model topic catalog (omnidash, OMN-4961)
# OMNIDASH_READ_MODEL_USE_CATALOG=  # auto-detect: true local, false k8s

# Auth toggle (omnidash)
OMNIDASH_AUTH_ENABLED=false

# External MCP gateway (omnidash)
OMNIDASH_ENABLE_EXTERNAL_GATEWAY=true
# ARCHON_ENABLE_EXTERNAL_GATEWAY=true  # alias

# Skip Keycloak provision (omniweb dev)
FEATURE_SKIP_PROVISION=false

# Waitlist mode (omniweb)
FEATURE_WAITLIST_MODE=true


# =============================================================================
# RUNTIME CONFIGURATION
# =============================================================================

# Application environment
NODE_ENV=development
ONEX_ENVIRONMENT=development
ONEX_LOG_LEVEL=INFO
LOG_LEVEL=INFO

# ONEX state directory — critical for hook state management
# Must exist on disk; used by omniclaude state manager
ONEX_STATE_DIR=

# ONEX pipeline state
# ONEX_TASK_ID=
# ONEX_RUN_ID=

# Plugin paths (auto-detected; override only if needed)
# OMNICLAUDE_PATH=
# CLAUDE_PLUGIN_ROOT=
# PROJECT_ROOT=

# Web server
PORT=3000
# OMNIDASH_PORT=3000
HOST=localhost

# WebSocket configuration (omnidash)
WS_PATH=/ws
WS_HEARTBEAT_INTERVAL_MS=30000
WS_MAX_MISSED_PINGS=2
WS_RECONNECT_DELAY_MS=1000
WS_RECONNECT_MAX_DELAY_MS=30000
WS_RECONNECT_MAX_ATTEMPTS=10

# API performance (omnidash)
ENABLE_RESPONSE_CACHE=true
API_CACHE_TTL_SECONDS=60
API_RATE_LIMIT_PER_MINUTE=100
API_RATE_LIMIT_BURST=20

# Metrics (omnidash)
METRICS_COLLECTION_INTERVAL_MS=60000
METRICS_RETENTION_MS=2592000000

# Event consumer (omnidash)
EVENT_DATA_RETENTION_MS=86400000
EVENT_PRUNE_INTERVAL_MS=3600000
EVENT_MAX_ACTIONS=100
EVENT_MAX_DECISIONS=100
EVENT_MAX_TRANSFORMATIONS=100
EVENT_MAX_PERFORMANCE_METRICS=200
EVENT_CONSUMER_VERBOSE_LOGGING=false
PRELOAD_WINDOW_MINUTES=1440

# Request logging (omnidash)
REQUEST_LOG_LEVEL=info
REQUEST_LOG_MAX_BODY_LENGTH=80

# Client-side URLs (omnidash)
# VITE_INTELLIGENCE_SERVICE_URL=http://localhost:8053
# VITE_API_BASE_URL=

# Analytics
# VITE_POSTHOG_API_KEY=
# VITE_POSTHOG_API_HOST=
# NEXT_PUBLIC_GA_MEASUREMENT_ID=
# NEXT_PUBLIC_APP_URL=https://app.omninode.ai
# UMAMI_WEBSITE_ID=


# =============================================================================
# DOCKER IMAGE VERSIONS
# =============================================================================

# QDRANT_VERSION=v1.16.3  # (set above)
MEMGRAPH_VERSION=2.18.1
# VALKEY_VERSION=8  # (set above)


# =============================================================================
# KUBERNETES & CLOUD (omninode_infra)
# =============================================================================

# KUBECONFIG=~/.kube/config
# KUBE_CONTEXT=
# AWS_PROFILE=
# AWS_REGION=


# =============================================================================
# TEST CONFIGURATION
# =============================================================================

PYTEST_ADDOPTS=-v --tb=short
TEST_VERBOSE=false
TEST_TIMEOUT=30
TEST_SKIP_SLOW=false
TEST_RETRIES=3
DEBUG=false
LOG_HTTP=false
SAVE_RESPONSES=false
RESPONSE_DIR=/tmp/omninode-test-responses

# Hook/plugin overrides (test only)
# LOG_FILE=
# PLUGIN_PYTHON_BIN=
# OMNICLAUDE_NO_HANDLERS=
# OMNICLAUDE_EMIT_SOCKET=
# OMNICLAUDE_EMIT_TIMEOUT=
