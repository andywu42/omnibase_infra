# OmniBase / ONEX .gitignore - Infrastructure-specific patterns

# Environment files (refined pattern)
# Match all .env variants (.env.local, .env.production, etc.)
# but preserve example files for documentation
.env*
!.env.example
.infisical-identity

# Virtual environments (consolidated - duplicates removed)
.venv/
venv/
ENV/
env.bak/

# VS Code
.vscode/

# MacOS
.DS_Store

# Logs (consolidated - duplicates removed)
*.log

# Docker runtime data directories
data/
logs/
generated/
reports/
secrets/

# Exception: contract-driven generated Python source must be committed
!src/omnibase_infra/enums/generated/

# Ignore sensitive and legacy files
legacy/
docs_private/

# Optimization cache files (consolidated - duplicates removed)
.onex_cache/
docs_archived/

# AI IDE tools (consolidated - duplicates removed)
.codanna/
.serena/
.cursor/
.hive-mind/
.swarm/
.claude-flow/
claude-flow.config.json

# Claude Code settings (personal/local configuration)
.claude/*
!.claude/architecture-handshake.md
*.db
*.sqlite
*.db-wal
*.db-shm
*.sqlite-journal
*system-metrics.json
*-metrics.json
session-*.json
*auto-save*.json

# Temporary files and caches
tmp/

# Development and Analysis Documents (temporary files)
*_ANALYSIS.md
*_SUMMARY.md
*_GUIDE.md
!docs/**/*_GUIDE.md
TEMP_*IMPLEMENTATION*.md
REFACTORING_EXAMPLE.py
examples_*.py
factory_pattern_analysis.md
migration_guide_*.md
coverage.json
.test_durations
junit-*.xml
.claude/settings.local.json
.infisical-admin-token
.infisical-admin-token.tmp
.infisical-identity.tmp

# Operational artifacts — never commit (OMN-4569)
# Recovery logs, validation logs, and session artifacts are auto-generated
# by automated tooling and must never be tracked as repo content.
docs/recovery/
*-validation-log-*.md
*-recovery-log-*.md
